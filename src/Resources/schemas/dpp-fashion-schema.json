{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Digital Product Passport - Fashion/Textile",
  "description": "EU Digital Product Passport schema for fashion and textile products",
  "type": "object",
  "required": ["dpp", "product"],
  "properties": {
    "dpp": {
      "type": "object",
      "description": "DPP metadata",
      "properties": {
        "version": {
          "type": "string",
          "default": "1.0"
        },
        "standard": {
          "type": "string",
          "default": "EU-DPP-2023"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "product": {
      "type": "object",
      "properties": {
        "identification": {
          "type": "object",
          "required": ["productId", "sku", "productName"],
          "properties": {
            "productId": {
              "type": "string",
              "description": "Unique product identifier"
            },
            "sku": {
              "type": "string",
              "description": "Stock Keeping Unit"
            },
            "productName": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "enum": ["T-Shirts", "Jeans", "Dresses", "Jackets", "Shoes", "Accessories"]
            },
            "description": {
              "type": "string"
            },
            "imageUrl": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "manufacturer": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "country": {
              "type": "string",
              "description": "ISO 3166-1 alpha-2 country code"
            },
            "contactEmail": {
              "type": "string",
              "format": "email"
            }
          }
        }
      }
    },
    "sustainability": {
      "type": "object",
      "properties": {
        "materials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "materialName": {
                "type": "string"
              },
              "materialType": {
                "type": "string",
                "enum": ["Natural Fiber", "Synthetic", "Regenerated", "Bio-based"]
              },
              "percentage": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "originCountry": {
                "type": "string",
                "description": "ISO 3166-1 alpha-2 country code"
              },
              "certification": {
                "type": "string"
              },
              "sourceType": {
                "type": "string",
                "enum": ["Organic", "Conventional", "Recycled", "Bio-based"]
              },
              "co2_per_kg": {
                "type": "number",
                "description": "CO2 emissions in kg per kg of material"
              },
              "waterConsumption_liters_per_kg": {
                "type": "number"
              },
              "chemicalTreatment": {
                "type": "string"
              }
            }
          }
        },
        "carbonFootprint": {
          "type": "object",
          "properties": {
            "total_kg_co2": {
              "type": "number"
            },
            "scope": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["production", "transportation", "packaging", "usage", "end-of-life"]
              }
            },
            "methodology": {
              "type": "string"
            }
          }
        },
        "waterConsumption": {
          "type": "object",
          "properties": {
            "total_liters": {
              "type": "number"
            },
            "scope": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "chemicalUsage": {
          "type": "object",
          "properties": {
            "dyes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "finishing": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "durability": {
      "type": "object",
      "properties": {
        "estimatedLifespanMonths": {
          "type": "integer"
        },
        "repairability": {
          "type": "object",
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "repairGuideUrl": {
              "type": "string",
              "format": "uri"
            },
            "replacementPartsAvailable": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "endOfLife": {
      "type": "object",
      "properties": {
        "recyclable": {
          "type": "boolean"
        },
        "recyclabilityScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "recyclingInstructions": {
          "type": "string"
        },
        "recyclingProgram": {
          "type": "string"
        }
      }
    },
    "compliance": {
      "type": "object",
      "properties": {
        "certifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "regulatoryStatus": {
          "type": "string",
          "enum": ["Compliant", "Non-compliant", "Pending"]
        }
      }
    },
    "supplyChain": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "object",
          "properties": {
            "country": {
              "type": "string"
            },
            "facility": {
              "type": "string"
            }
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stage": {
                "type": "string"
              },
              "location": {
                "type": "string"
              },
              "certifications": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "dppCreatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "default": "en"
        }
      }
    }
  }
}
