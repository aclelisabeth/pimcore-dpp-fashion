# ⚠️ IMPORTANT: Change these default credentials BEFORE using in production!
# This file is for LOCAL DEVELOPMENT ONLY
# Create this file as .env (without .example) and change values

PIMCORE_ADMIN_USERNAME=admin
PIMCORE_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD_IMMEDIATELY
PIMCORE_ADMIN_EMAIL=admin@example.com

DATABASE_URL=mysql://pimcore:pimcore@db:3306/pimcore?serverVersion=8.0
REDIS_URL=redis://redis:6379/0

PIMCORE_ENVIRONMENT=dev
PIMCORE_DEBUG=true

MAILER_DSN=null://localhost

# API Configuration
DPP_API_ENABLED=true
DPP_API_VERSION=1.0
DPP_STANDARD=EU-DPP-2023

# Fashion specific settings
DPP_FASHION_ENABLED=true
DPP_EXPORT_FORMATS=json,xml,pdf

# ⚠️ FOR DEVELOPMENT ONLY - NEVER USE WEAK PASSWORDS IN PRODUCTION
# Generate strong password: openssl rand -base64 32
